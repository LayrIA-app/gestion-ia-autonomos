# ════════════════════════════════════════════════════════════════════
# Variables de entorno COAXIONIA · Gestión IA Autónomos
# ════════════════════════════════════════════════════════════════════
# Copia este archivo a .env.local para desarrollo local.
# En producción: añadir estas variables en Vercel → Settings → Environment Variables.
# Sin estas variables la app arranca en modo Fase 1 (datos mock, sin backend real).
# ════════════════════════════════════════════════════════════════════

# ─── Fase 2 ────────────────────────────────────────────────────────

# Supabase · auth + base de datos + realtime (cliente, exposed al browser)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx

# Anthropic · Claude Opus 4.7 para IA proactiva (server-only, API route)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx

# Resend · envío de emails (facturas, recordatorios, propuestas) (server-only)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=noreply@arrietaconsultores.com

# ─── Fase 3 ────────────────────────────────────────────────────────

# Stripe · cobros con tarjeta desde portal cliente (server-only)
# Test mode: sk_test_... · Live mode: sk_live_...
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Supabase service role · solo server-side · bypass RLS para webhook Stripe
# que actualiza facturas_emitidas.estado='cobrada' sin sesión de usuario.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxx
